{
  "name": "tecm8",
  "version": "0.1.0",
  "private": true,
  "description": "Proof and project tooling for TECM8, the TEC-1G development environment.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types tools/*.test.ts tools/**/*.test.ts",
    "fs": "node --experimental-strip-types tools/fs.ts",
    "proof:storage:image": "node --experimental-strip-types tools/create-storage-proof-image.ts",
    "proof:storage:image:verify": "node --experimental-strip-types tools/create-storage-proof-image.ts --verify-only",
    "proof:storage": "node --experimental-strip-types tools/run-storage-proof.ts",
    "proof:storage:check": "node --experimental-strip-types tools/check-storage-proof-status.ts --strict",
    "proof:project-config": "node --experimental-strip-types tools/run-project-config-proof.ts",
    "proof:project-config:storage": "node --experimental-strip-types tools/run-project-config-storage-proof.ts",
    "proof:display": "node --experimental-strip-types tools/run-display-proof.ts",
    "proof:display:glcd-tile": "node --experimental-strip-types tools/run-display-proof.ts glcd-tile-proof",
    "proof:display:structured": "node --experimental-strip-types tools/run-display-proof.ts structured-screen-proof",
    "proof:display:editor-viewport": "node --experimental-strip-types tools/run-display-proof.ts editor-viewport-proof",
    "proof:display:editor-viewport:metadata-record": "node --experimental-strip-types tools/run-display-proof.ts editor-viewport-metadata-record-proof",
    "proof:display:editor-viewport:storage": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts",
    "proof:display:editor-viewport:storage:invalid-page": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-viewport-storage-invalid-page-proof",
    "proof:display:editor-viewport:storage:small-file": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-viewport-storage-small-file-proof",
    "proof:display:editor-navigation": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-navigation-proof",
    "proof:display:shell-edit-navigation": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts shell-edit-navigation-proof",
    "proof:display:shell-edit-explicit-navigation": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts shell-edit-explicit-navigation-proof",
    "proof:display:shell-edit-named-navigation": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts shell-edit-named-navigation-proof",
    "proof:display:shell-edit-create-source": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts shell-edit-create-source-proof",
    "proof:display:editor-file-list": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-file-list-proof",
    "proof:display:shell-edit-interaction": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts shell-edit-interaction-proof",
    "proof:display:editor-dirty-render": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-dirty-render-proof",
    "proof:display:editor-mutation-boundary": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-mutation-boundary-proof",
    "proof:display:editor-cross-page-join": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-cross-page-join-proof",
    "proof:display:editor-window-save": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-window-save-proof",
    "proof:display:editor-row15-growth": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-row15-growth-proof",
    "proof:display:editor-viewport-scroll": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-viewport-scroll-proof",
    "proof:display:editor-horizontal-scroll": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-horizontal-scroll-proof",
    "proof:display:editor-allocation-growth": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-allocation-growth-proof",
    "proof:display:editor-line-editing": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-line-editing-proof",
    "proof:display:editor-page-write": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-page-write-proof",
    "proof:display:editor-error-handling": "node --experimental-strip-types tools/run-editor-viewport-storage-proof.ts editor-error-handling-proof",
    "debug80:editor-image": "node --experimental-strip-types tools/run-debug80-editor-session.ts --prepare-only",
    "debug80:editor-session": "node --experimental-strip-types tools/run-debug80-editor-session.ts",
    "debug80:editor-live-smoke": "node --experimental-strip-types tools/run-debug80-editor-session.ts --live-smoke",
    "proof:shell-commands": "node --experimental-strip-types tools/run-shell-commands-proof.ts",
    "mon3:inventory": "node --experimental-strip-types tools/mon3-service-inventory.ts",
    "mon3:inventory:check": "node --experimental-strip-types tools/mon3-service-inventory.ts --check",
    "mon3:storage-split": "node --experimental-strip-types tools/mon3-storage-split.ts",
    "mon3:storage-split:check": "node --experimental-strip-types tools/mon3-storage-split.ts --check",
    "mon3:glcd-split": "node --experimental-strip-types tools/mon3-glcd-split.ts",
    "mon3:glcd-split:check": "node --experimental-strip-types tools/mon3-glcd-split.ts --check",
    "audit:storage": "node --experimental-strip-types tools/audit-storage-proof.ts",
    "quality": "fallow --root . --skip dead-code || true",
    "check": "npm run typecheck && npm run test && npm run mon3:inventory:check && npm run mon3:storage-split:check && npm run mon3:glcd-split:check && npm run proof:project-config && npm run proof:project-config:storage && npm run proof:display && npm run proof:display:glcd-tile && npm run proof:display:structured && npm run proof:display:editor-viewport && npm run proof:display:editor-viewport:metadata-record && npm run proof:display:editor-viewport:storage && npm run proof:display:editor-viewport:storage:invalid-page && npm run proof:display:editor-viewport:storage:small-file && npm run proof:display:editor-navigation && npm run proof:display:shell-edit-navigation && npm run proof:display:shell-edit-explicit-navigation && npm run proof:display:shell-edit-named-navigation && npm run proof:display:shell-edit-create-source && npm run proof:display:editor-file-list && npm run proof:display:shell-edit-interaction && npm run proof:display:editor-dirty-render && npm run proof:display:editor-mutation-boundary && npm run proof:display:editor-cross-page-join && npm run proof:display:editor-window-save && npm run proof:display:editor-row15-growth && npm run proof:display:editor-viewport-scroll && npm run proof:display:editor-horizontal-scroll && npm run proof:display:editor-allocation-growth && npm run proof:display:editor-line-editing && npm run proof:display:editor-page-write && npm run proof:display:editor-error-handling && npm run debug80:editor-session && npm run debug80:editor-live-smoke && npm run proof:shell-commands && npm run proof:storage:check && npm run audit:storage"
  },
  "devDependencies": {
    "@jhlagado/azm": "^0.2.10",
    "@types/node": "^25.9.1",
    "fallow": "^2.86.0",
    "typescript": "^6.0.3"
  }
}
